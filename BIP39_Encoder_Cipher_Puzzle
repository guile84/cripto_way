rouble truck true truly trumpet trust truth try tube tuition tumble tuna tunnel turkey turn turtle twelve twenty twice twin twist two type typical ugly umbrella unable unaware uncle uncover under undo unfair unfold unhappy uniform unique unit universe unknown unlock until unusual unveil update upgrade uphold upon upper upset urban urge usage use used useful useless usual utility vacant vacuum vague valid valley valve van vanish vapor various vast vault vehicle velvet vendor venture venue verb verify version very vessel veteran viable vibrant vicious victory video view village vintage violin virtual virus visa visit visual vital vivid vocal voice void volcano volume vote voyage wage wagon wait walk wall walnut want warfare warm warrior wash wasp waste water wave way wealth weapon wear weasel weather web wedding weekend weird welcome west wet whale what wheat wheel when where whip whisper wide width wife wild will win window wine wing wink winner winter wire wisdom wise wish witness wolf woman wonder wood wool word work world worry worth wrap wreck wrestle wrist write wrong yard year yellow you young youth zebra zero zone zoo";
    const bip39 = bip39_string.split(" ");

    // --- FUNÇÕES DE CONVERSÃO BIP39 <-> BIN/NUM ---

    // Palavras -> Binário (11 bits por palavra)
    function wordsToBinary(words) {
        return words.map(w => {
            let idx = bip39.indexOf(w.toLowerCase());
            if(idx === -1) throw new Error(`Palavra inválida: ${w}`);
            return idx.toString(2).padStart(11, '0');
        }).join('');
    }

    // Binário -> Palavras
    function binaryToWords(bin) {
        let words = [];
        for(let i=0; i < bin.length; i+=11) {
            let chunk = bin.substring(i, i+11);
            words.push(bip39[parseInt(chunk, 2)]);
        }
        return words;
    }

    // Binário -> BigInt Numérico
    function binaryToNum(bin) {
        return BigInt("0b" + bin).toString(10);
    }

    // BigInt Numérico -> Binário (precisa saber o tamanho em bits, ex: 132 ou 264)
    function numToBinary(numStr, bitsCount) {
        let bin = BigInt(numStr).toString(2);
        return bin.padStart(bitsCount, '0');
    }

    // --- FUNÇÕES DO PUZZLE (EMBARALHAMENTO E SEED) ---

    // PRNG simples
    function mulberry32(a) {
        return function() {
          var t = a += 0x6D2B79F5;
          t = Math.imul(t ^ t >>> 15, t | 1);
          t ^= t + Math.imul(t ^ t >>> 7, t | 61);
          return ((t ^ t >>> 14) >>> 0) / 4294967296;
        }
    }

    // Fisher-Yates determinístico
    function getPermutation(n, seed) {
        let prng = mulberry32(seed);
        let arr = Array.from({length: n}, (_, i) => i);
        for (let i = n - 1; i > 0; i--) {
            let j = Math.floor(prng() * (i + 1));
            let temp = arr[i];
            arr[i] = arr[j];
            arr[j] = temp;
        }
        return arr;
    }

    // Seed Numérica -> 3 Palavras
    function seedToWords(num) {
        let w1 = num % 2048; num = Math.floor(num / 2048);
        let w2 = num % 2048; num = Math.floor(num / 2048);
        let w3 = num % 2048;
        return `${bip39[w1]} ${bip39[w2]} ${bip39[w3]}`;
    }

    // 3 Palavras -> Seed Numérica
    function wordsToSeed(wordsStr) {
        let w = wordsStr.trim().split(/\s+/);
        if (w.length !== 3) throw new Error("Chave deve ter 3 palavras.");
        let i1 = bip39.indexOf(w[0].toLowerCase());
        let i2 = bip39.indexOf(w[1].toLowerCase());
        let i3 = bip39.indexOf(w[2].toLowerCase());
        if (i1 === -1 || i2 === -1 || i3 === -1) throw new Error("Palavra de chave inválida.");
        return i1 + (i2 * 2048) + (i3 * 4194304);
    }

    // --- INTERAÇÕES DA INTERFACE ---

    let currentInputWords = [];

    function processOriginal() {
        try {
            let input = document.getElementById('inputWords').value.trim().split(/\s+/);
            if(input.length < 12) throw new Error("Insira pelo menos 12 palavras.");
            
            currentInputWords = input;
            let bin = wordsToBinary(input);
            let num = binaryToNum(bin);

            document.getElementById('origBin').innerText = bin;
            document.getElementById('origNum').innerText = num;
            document.getElementById('originalOutputs').style.display = 'block';
            document.getElementById('scrambleOutputs').style.display = 'none';
        } catch(e) {
            alert(e.message);
        }
    }

    function scramble() {
        if(currentInputWords.length < 12) {
            alert("Por favor, analise a carteira original primeiro.");
            return;
        }

        // Gera seed de 32 bits
        let seed = Math.floor(Math.random() * 0xFFFFFFFF);
        let p = getPermutation(currentInputWords.length, seed);
        
        let scrambled = new Array(currentInputWords.length);
        for(let i = 0; i < currentInputWords.length; i++) {
            scrambled[i] = currentInputWords[p[i]];
        }

        // Output da Carteira Embaralhada
        let sBin = wordsToBinary(scrambled);
        document.getElementById('scrambledWords').innerText = scrambled.join(" ");
        document.getElementById('scrambledBin').innerText = sBin;
        document.getElementById('scrambledNum').innerText = binaryToNum(sBin);

        // Output da Chave
        document.getElementById('keyNum').innerText = seed.toString();
        document.getElementById('keyBin').innerText = seed.toString(2).padStart(32, '0');
        document.getElementById('keyWords').innerText = seedToWords(seed);

        document.getElementById('scrambleOutputs').style.display = 'block';
    }

    function descramble() {
        let dataInput = document.getElementById('recoverData').value.trim();
        let keyInput = document.getElementById('recoverKey').value.trim();

        if(!dataInput || !keyInput) {
            alert("Preencha os dados e a chave de recuperação.");
            return;
        }

        try {
            // 1. Interpretar os DADOS DA CARTEIRA
            let walletWords = [];
            if(dataInput.match(/^[01]+$/) && dataInput.length >= 132) {
                // É binário puro
                walletWords = binaryToWords(dataInput);
            } else if(dataInput.match(/^\d+$/)) {
                // É número gigante (BigInt)
                // Precisamos deduzir se era 12 ou 24 palavras arredondando para cima
                let tempBin = BigInt(dataInput).toString(2);
                let wordCount = Math.max(12, Math.ceil(tempBin.length / 11));
                if (wordCount > 12 && wordCount <= 15) wordCount = 15;
                else if (wordCount > 15 && wordCount <= 18) wordCount = 18;
                else if (wordCount > 18 && wordCount <= 21) wordCount = 21;
                else if (wordCount > 21) wordCount = 24;
                
                let bitsCount = wordCount * 11;
                let fullBin = numToBinary(dataInput, bitsCount);
                walletWords = binaryToWords(fullBin);
            } else {
                // Assume que são palavras com espaços
                walletWords = dataInput.split(/\s+/);
            }

            // 2. Interpretar a CHAVE
            let seed = 0;
            if (keyInput.match(/^[01]{1,32}$/)) {
                seed = parseInt(keyInput, 2);
            } else if (keyInput.match(/^\d+$/)) {
                seed = parseInt(keyInput, 10);
            } else if (keyInput.includes(" ") && keyInput.split(/\s+/).length === 3) {
                seed = wordsToSeed(keyInput);
            } else {
                throw new Error("Formato da chave não reconhecido.");
            }

            // 3. Desembaralhar
            let p = getPermutation(walletWords.length, seed);
            let original = new Array(walletWords.length);
            for(let i = 0; i < p.length; i++) {
                original[p[i]] = walletWords[i]; // Inversão do Fisher-Yates
            }

            document.getElementById('restoredWords').innerText = original.join(" ");
            document.getElementById('recoverOutputs').style.display = 'block';

        } catch(e) {
            alert("Erro ao recuperar: " + e.message);
        }
    }
</script>
